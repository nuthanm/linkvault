# Copy this to .env.local for local dev. On Vercel, set these in Project Settings → Environment Variables.

# From Neon → Connection Details → "Pooled connection" (recommended for serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# A long random string. Used as the password to add/edit/delete links.
# Generate one with:  openssl rand -base64 32
ADMIN_PASSWORD=change-me-to-a-long-random-string
